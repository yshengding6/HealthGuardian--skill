        "red": {"min": 81, "max": 500, "label": "中重度升高"}
      },
      "ast": {
        "green": {"min": 0, "max": 40, "label": "正常"},
        "orange": {"min": 41, "max": 80, "label": "轻度升高"},
        "red": {"min": 81, "max": 500, "label": "中重度升高"}
      }
    },
