    "physical_activity": {
      "name": "运动量",
      "unit": "步数",
      "daily_steps": {
        "green": {"min": 8000, "max": 20000, "label": "优秀"},
        "orange": {"min": 5000, "max": 7999, "label": "一般"},
        "red": {"min": 0, "max": 4999, "label": "不足"}
      }
    }
