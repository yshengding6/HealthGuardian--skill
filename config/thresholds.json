{
  "health_thresholds": {
    "blood_pressure": {
      "name": "血压",
      "unit": "mmHg",
      "systolic": {
        "green": {"min": 0, "max": 119, "label": "正常"},
        "orange": {"min": 120, "max": 139, "label": "偏高"},
        "red": {"min": 140, "max": 300, "label": "高血压"},
        "critical": {"min": 160, "max": 300, "label": "严重高血压"}
      },
      "diastolic": {
        "green": {"min": 0, "max": 79, "label": "正常"},
        "orange": {"min": 80, "max": 89, "label": "偏高"},
        "red": {"min": 90, "max": 200, "label": "高血压"},
        "critical": {"min": 100, "max": 200, "label": "严重高血压"}
      }
    },
    "blood_glucose": {
      "name": "血糖",
      "unit": "mmol/L",
