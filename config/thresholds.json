  "alert_rules": {
    "continuous_abnormal_days": 7,
    "critical_immediate_alert": true,
    "orange_summary_days": 3,
    "severity_mapping": {
      "green": "无",
      "orange": "轻微",
      "red": "中度",
      "critical": "严重"
    }
  },
  "weekly_report_config": {
    "include_trends": true,
    "compare_previous_week": true,
    "highlight_changes": true,
    "min_records_for_trend": 3
  }
}